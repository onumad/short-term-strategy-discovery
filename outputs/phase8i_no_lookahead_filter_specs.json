  {
    "description": "Keep every de-duplicated baseline trade.",
    "filter_family": "all",
    "filter_id": "baseline_all",
    "params": {}
  },
  {
    "description": "Only entries in the first RTH half-hour.",
    "filter_family": "time_window",
    "filter_id": "time_window:first_30",
    "params": {
