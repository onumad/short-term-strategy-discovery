      "start": "09:30"
    }
  },
  {
    "description": "Only entries before 11:00 ET.",
    "filter_family": "time_window",
    "filter_id": "time_window:first_90",
    "params": {
      "end": "11:00",
      "start": "09:30"
    }
  },
  {
    "description": "Only entries before noon ET.",
    "filter_family": "time_window",
    "filter_id": "time_window:morning",
    "params": {
      "end": "12:00",
      "start": "09:30"
    }
  },
  {
    "description": "Only entries before 14:00 ET.",
    "filter_family": "time_window",
    "filter_id": "time_window:pre_14_00",
    "params": {
      "end": "14:00",
      "start": "09:30"
    }
  },
  {
    "description": "Only midday continuation entries.",
    "filter_family": "time_window",
    "filter_id": "time_window:midday_12_14",
    "params": {
